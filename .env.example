# MongoDB connection (required)
MONGODB_URI=mongodb://127.0.0.1:27017/yuse

# Server
PORT=4000

# Optional: absolute URL prefix (origin) for upload responses — scheme + host; include port if not 80/443 (e.g. https://api.example.com:8443). Default: relative `/uploads/...`.
# PUBLIC_BASE_URL=https://api.example.com

# JWT signing secret — use a long random string in production
JWT_SECRET=change-me-to-a-long-random-secret

# CORS: comma-separated origins (default includes Next dev)
CORS_ORIGINS=http://localhost:3000

# Optional: create an admin user on startup if this username does not exist yet
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=your-secure-password

# Optional: path to sample task JSON to seed when DB has no tasks (relative to backend cwd)
# SAMPLE_TASK_PATH=../demo/dev/task-sample.v4.8.json
